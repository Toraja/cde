# Copy this file as .env and set value of each variables.
# Optional variables are commented out.

# === common ===
# Set the privilege escalation password of the current user
ANSIBLE_BECOME_PASS=

# Filename of github private key. Must be placed in ~/.ssh.
# Setting this will add the key to keychain.
# GITHUB_SSH_KEY=
# Set this to increase rate limit for github during building image.
# No scope is required just to increase the rate limit.
# GITHUB_TOKEN=

# === catalog specific ===
